#!/usr/bin/env python3
import os, subprocess, sys, shlex, argparse, signal
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

try:
    import customtkinter as ctk
    from tkinter import filedialog
    GUI_AVAILABLE = True
except ImportError:
    GUI_AVAILABLE = False

try:
    from rich.progress import Progress, SpinnerColumn, BarColumn, TextColumn, TimeRemainingColumn
    from rich.console import Console
except ImportError:
    print("Missing dependency: rich")
    sys.exit(1)

DEFAULT_PATH = "/mnt/synology/Keithens folder/OBS Output"

FFMPEG_CMD = [
    "ffmpeg", "-y", "-i", "{input}",
    "-c:v", "dnxhd", "-profile:v", "dnxhr_lb",
    "-pix_fmt", "yuv422p",
    "-c:a", "pcm_s16le",
    "-f", "mov", "{output}"
]

console = Console()
running_processes = []

def _sigint_handler(sig, frame):
    console.print("\n[red]Interrupted, cleaning up...[/]")
    for proc, out in running_processes:
        try:
            proc.terminate()
        except Exception:
            pass
        if out.exists():
            try:
                out.unlink()
            except Exception:
                pass
    sys.exit(1)

signal.signal(signal.SIGINT, _sigint_handler)

def get_duration(file_path):
    cmd = [
        "ffprobe", "-v", "error",
        "-show_entries", "format=duration",
        "-of", "default=noprint_wrappers=1:nokey=1",
        str(file_path)
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    try:
        return float(result.stdout.strip())
    except Exception:
        return 0

def check_ffmpeg():
    if subprocess.run(["which", "ffmpeg"], capture_output=True).returncode != 0:
        console.print("[red]ffmpeg not installed[/]")
        sys.exit(1)

def process_video(video_path, progress, task_id, quick_mode, delete_source):
    output_dir = video_path.parent / "Done"
    output_dir.mkdir(exist_ok=True)

    output_path = output_dir / f"{video_path.stem}.mov"
    source_dur = get_duration(video_path)

    if output_path.exists():
        existing = get_duration(output_path)
        if quick_mode or abs(existing - source_dur) < 2.0:
            progress.update(task_id, completed=source_dur or 100)
            if delete_source:
                video_path.unlink()
            return

    cmd = [c.format(input=str(video_path), output=str(output_path)) for c in FFMPEG_CMD]
    cmd += ["-progress", "pipe:1", "-nostats"]

    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
    running_processes.append((proc, output_path))

    while True:
        line = proc.stdout.readline()
        if not line and proc.poll() is not None:
            break

        if line.startswith("out_time_ms="):
            try:
                t = int(line.split("=")[1]) / 1_000_000
                progress.update(task_id, completed=t)
            except Exception:
                pass

        elif line.startswith("progress=end"):
            progress.update(task_id, completed=source_dur or 100)

    proc.wait()

    try:
        running_processes.remove((proc, output_path))
    except ValueError:
        pass

    if proc.returncode == 0:
        progress.update(task_id, description=f"[green]✓ {video_path.name}")
        if delete_source:
            video_path.unlink()
    else:
        progress.update(task_id, description=f"[red]✗ {video_path.name}")
        if output_path.exists():
            output_path.unlink()

def run_resolvify(path, quick, delete, overnight, workers=2):
    check_ffmpeg()

    scan_path = Path(path)
    if not scan_path.exists():
        console.print("[red]Path not found[/]")
        sys.exit(1)

    files = [
        f for f in scan_path.iterdir()
        if f.is_file() and f.suffix.lower() in {".mp4", ".mkv", ".mov"}
    ]

    if not files:
        console.print("[yellow]No videos found[/]")
        return

    console.print(f"[cyan]Found {len(files)} files[/]\n")

    with Progress(
        SpinnerColumn(),
        TextColumn("{task.description}"),
        BarColumn(),
        TimeRemainingColumn(),
        console=console,
        expand=True
    ) as progress:

        with ThreadPoolExecutor(max_workers=workers) as ex:
            futures = []

            for f in files:
                dur = get_duration(f) if not quick else 100
                tid = progress.add_task(f.name, total=max(dur, 1))
                futures.append(ex.submit(process_video, f, progress, tid, quick, delete))

            for fut in futures:
                try:
                    fut.result()
                except Exception as e:
                    console.print(f"[red]{e}[/]")

    console.print("[green]Done[/]")

    if overnight:
        os.system("sudo shutdown -h +1")

class App(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Resolvify")
        self.geometry("420x560")
        self.resizable(False, False)

        ctk.CTkLabel(self, text="Resolvify", font=("Arial", 24, "bold")).pack(pady=20)

        self.path = ctk.StringVar(value=DEFAULT_PATH)

        frame = ctk.CTkFrame(self)
        frame.pack(fill="x", padx=20)

        ctk.CTkButton(frame, text="Pick Folder", command=self.pick).pack(side="left", padx=10, pady=10)
        ctk.CTkLabel(frame, textvariable=self.path, wraplength=240).pack(side="left")

        self.q = ctk.BooleanVar()
        self.d = ctk.BooleanVar(value=True)
        self.o = ctk.BooleanVar()

        opts = ctk.CTkFrame(self)
        opts.pack(fill="x", padx=20, pady=10)

        ctk.CTkCheckBox(opts, text="Quick", variable=self.q).pack(anchor="w")
        ctk.CTkCheckBox(opts, text="Delete source", variable=self.d).pack(anchor="w")
        ctk.CTkCheckBox(opts, text="Shutdown", variable=self.o).pack(anchor="w")

        self.workers = ctk.IntVar(value=2)

        ctk.CTkSlider(self, from_=1, to=8, variable=self.workers).pack(fill="x", padx=20)

        ctk.CTkButton(self, text="Run", fg_color="#2a7a2a", command=self.run).pack(pady=20, fill="x", padx=20)

    def pick(self):
        f = filedialog.askdirectory()
        if f:
            self.path.set(f)

    def run(self):
        subprocess.Popen([
            sys.executable, __file__,
            "--path", self.path.get(),
            "--workers", str(self.workers.get()),
            *(["--quick"] if self.q.get() else []),
            *(["--delete"] if self.d.get() else []),
            *(["--overnight"] if self.o.get() else [])
        ])
        self.iconify()

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--path")
    parser.add_argument("--quick", action="store_true")
    parser.add_argument("--delete", action="store_true")
    parser.add_argument("--overnight", action="store_true")
    parser.add_argument("--workers", type=int, default=2)
    parser.add_argument("--gui", action="store_true")
    args = parser.parse_args()

    if args.gui or not args.path:
        if not GUI_AVAILABLE:
            print("GUI missing")
            sys.exit(1)
        App().mainloop()
    else:
        run_resolvify(args.path, args.quick, args.delete, args.overnight, args.workers)

if __name__ == "__main__":
    main()
